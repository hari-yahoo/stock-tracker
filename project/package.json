
{
  "name": "stock-tracker",
  "private": true,
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "postbuild:frontend": "rm -rf backend/public && cp -r frontend/dist backend/public",
    "build": "npm run build:frontend && npm run postbuild:frontend && npm run build:backend",
    "start": "node backend/dist/main.js"
  }
}