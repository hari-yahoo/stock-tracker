
{
  "name": "stock-tracker",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm run start:dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build:frontend": "npm run build -w frontend",
    "build:backend": "npm run build -w backend",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "npm run start:prod -w backend",
    "lint": "npm run lint -w frontend && npm run lint -w backend",
    "test": "npm test -w backend -- --runInBand",
    "test:e2e": "npm run test:e2e -w backend -- --runInBand",
    "check": "npm run lint && npm test && npm run build"
  }
}
