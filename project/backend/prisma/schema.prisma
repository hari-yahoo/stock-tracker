generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum TradeSide {
  BUY
  SELL
}

enum TradeStatus {
  POSTED
  VOIDED
}

enum InstrumentType {
  EQUITY
  ETF
}

enum ExitPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Account {
  id                String   @id @default(uuid())
  name              String   @unique
  description       String?
  reportingCurrency String   @default("INR") @map("reporting_currency")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  trades            Trade[]

  @@map("accounts")
}

model Instrument {
  id             String          @id @default(uuid())
  symbol         String
  exchange       String
  name           String?
  sector         String?
  quoteCurrency  String          @map("quote_currency")
  instrumentType InstrumentType  @default(EQUITY) @map("instrument_type")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  trades         Trade[]
  prices         PriceSnapshot[]
  exitPlan       StockExitPlan?

  @@unique([symbol, exchange])
  @@index([symbol])
  @@map("instruments")
}

model IciciSymbolMapping {
  id          String   @id @default(uuid())
  iciciSymbol String   @unique @map("icici_symbol")
  nseSymbol   String   @map("nse_symbol")
  companyName String?  @map("company_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([nseSymbol])
  @@map("icici_symbol_mappings")
}

/// Economic fields on a posted trade are immutable. Corrections void the
/// original trade and append a replacement in one database transaction.
model Trade {
  id                 String          @id @default(uuid())
  accountId          String          @map("account_id")
  instrumentId       String          @map("instrument_id")
  side               TradeSide
  status             TradeStatus     @default(POSTED)
  quantityMicros     BigInt          @map("quantity_micros")
  priceMicros        BigInt          @map("price_micros")
  feesMicros         BigInt          @default(0) @map("fees_micros")
  executedAt         DateTime        @map("executed_at")
  externalReference  String?         @map("external_reference")
  notes              String?
  recordedAt         DateTime        @default(now()) @map("recorded_at")
  voidedAt           DateTime?       @map("voided_at")
  account            Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  instrument         Instrument      @relation(fields: [instrumentId], references: [id], onDelete: Restrict)
  openingAllocations LotAllocation[] @relation("OpeningTrade")
  closingAllocations LotAllocation[] @relation("ClosingTrade")

  @@unique([accountId, externalReference])
  @@index([accountId, instrumentId, executedAt])
  @@index([instrumentId, executedAt])
  @@map("trades")
}

/// Allocates a SELL quantity to a BUY lot. A sell can close several lots and
/// a lot can be closed by several sells.
model LotAllocation {
  id             String   @id @default(uuid())
  openingTradeId String   @map("opening_trade_id")
  closingTradeId String   @map("closing_trade_id")
  quantityMicros BigInt   @map("quantity_micros")
  createdAt      DateTime @default(now()) @map("created_at")
  openingTrade   Trade    @relation("OpeningTrade", fields: [openingTradeId], references: [id], onDelete: Restrict)
  closingTrade   Trade    @relation("ClosingTrade", fields: [closingTradeId], references: [id], onDelete: Restrict)

  @@unique([openingTradeId, closingTradeId])
  @@index([closingTradeId])
  @@map("lot_allocations")
}

model StockExitPlan {
  id                String         @id @default(uuid())
  instrumentId      String         @unique @map("instrument_id")
  targetPriceMicros BigInt         @map("target_price_micros")
  targetDate        DateTime       @map("target_date")
  rationale         String
  status            ExitPlanStatus @default(ACTIVE)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  instrument        Instrument     @relation(fields: [instrumentId], references: [id], onDelete: Restrict)

  @@index([status, targetDate])
  @@map("stock_exit_plans")
}

model PriceSnapshot {
  id           String     @id @default(uuid())
  instrumentId String     @map("instrument_id")
  priceMicros  BigInt     @map("price_micros")
  capturedAt   DateTime   @map("captured_at")
  source       String     @default("MANUAL")
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@unique([instrumentId, capturedAt])
  @@index([capturedAt])
  @@map("price_snapshots")
}

model FxRateSnapshot {
  id            String   @id @default(uuid())
  baseCurrency  String   @map("base_currency")
  quoteCurrency String   @map("quote_currency")
  rateNanos     BigInt   @map("rate_nanos")
  capturedAt    DateTime @map("captured_at")
  source        String   @default("MANUAL")

  @@unique([baseCurrency, quoteCurrency, capturedAt])
  @@index([capturedAt])
  @@map("fx_rate_snapshots")
}

model PortfolioDailySnapshot {
  id                   String   @id @default(uuid())
  asOfDate             String   @map("as_of_date")
  reportingCurrency    String   @map("reporting_currency")
  investedAmountMicros BigInt?  @map("invested_amount_micros")
  marketValueMicros    BigInt?  @map("market_value_micros")
  capturedAt           DateTime @map("captured_at")
  source               String   @default("DAILY_PROCESS")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([reportingCurrency, asOfDate])
  @@index([capturedAt])
  @@map("portfolio_daily_snapshots")
}
